# MCP LLM Gateway Configuration
# Copy this to config.yaml and customize for your setup
#
# Get available models from: https://models.dev/api.json

model_list_url: "https://models.dev/api.json"
cache_ttl: 300

providers:
  - id: "openai"
    name: "OpenAI"
    type: "openai"
    base_url: "https://api.openai.com/v1"
    api_key: "${OPENAI_API_KEY}"
    default_model: "gpt-4o"
    fallback_models:
      - "gpt-4-turbo"
      - "gpt-4"
      - "gpt-3.5-turbo"
    timeout: 60
    enabled: true

  - id: "anthropic"
    name: "Anthropic"
    type: "anthropic"
    base_url: "https://api.anthropic.com/v1"
    api_key: "${ANTHROPIC_API_KEY}"
    default_model: "claude-sonnet-4-20250514"
    fallback_models:
      - "claude-3-5-sonnet-20241022"
      - "claude-3-opus-20240229"
      - "claude-3-sonnet-20240229"
    timeout: 60
    enabled: true

  - id: "google"
    name: "Google"
    type: "google"
    base_url: "https://generativelanguage.googleapis.com/v1beta"
    api_key: "${GOOGLE_API_KEY}"
    default_model: "gemini-2.0-flash-exp"
    fallback_models:
      - "gemini-1.5-pro"
      - "gemini-1.5-flash"
    timeout: 60
    enabled: true

  - id: "local"
    name: "Local LLM"
    type: "openai"
    base_url: "http://localhost:11434/v1"
    api_key: "not-required"
    default_model: "llama3"
    fallback_models:
      - "llama2"
      - "mistral"
    timeout: 120
    enabled: false